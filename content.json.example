{
  // ============================================================
  // content.json — 截图配置示例
  // 每张图一个对象，按顺序生成
  // 完整教程见小报童专栏
  // ============================================================

  "assetType": "tool",              // 固定值，标记使用统一模板
  "outputDir": "./Images",          // 截图输出目录（相对路径）
  "headless": true,                 // true=无头截图，false=可见浏览器

  "images": [
    // ==================================================================
    // 1. 封面（每期必有一张）
    // ==================================================================
    {
      "type": "cover",
      "filename": "001-method-01-cover",           // 输出文件名（不含扩展名）
      "title": "标题文字<br><span class=\"hl\">高亮词</span>",  // 支持<br>换行
      "subtitle": "副标题",
      "tagline": "口号文字",
      "badges": ["🏷️ 标签1", "🏷️ 标签2", "🏷️ 标签3"],  // 每个badge必须有emoji
      "bgImage": "cover-bg.png"                    // （可选）封面背景图
    },

    // ==================================================================
    // 2. 卡片内容页（并列要点/多卡片）
    // ==================================================================
    {
      "type": "content",
      "filename": "001-method-02-pain",
      "pageNum": "01",                              // 页码
      "sectionTitle": "页面标题",
      "footerText": "底部文字",
      "cards": [
        {"icon": "💡", "title": "卡片标题", "desc": "卡片描述文字"},
        {"icon": "❌", "title": "卡片标题", "desc": "卡片描述文字"},
        {"icon": "🤝", "title": "卡片标题", "desc": "卡片描述文字"}
      ]
    },

    // ==================================================================
    // 3. 展示页（截图展示，自动拆页）
    // 超过 max_showcase_items(2) 张截图，脚本自动拆为多页
    // ==================================================================
    {
      "type": "showcase",
      "filename": "001-method-03-features",
      "pageNum": "02",
      "sectionTitle": "展示页面标题",
      "footerText": "底部文字",
      "items": [
        {"image": "screenshot-1.png", "title": "截图标题1", "desc": "描述文字"},
        {"image": "screenshot-2.png", "title": "截图标题2", "desc": "描述文字"},
        // 超过2张自动拆分到下一页面，文件名追加 -2
        {"image": "screenshot-3.png", "title": "截图标题3", "desc": "描述文字"},
        {"image": "screenshot-4.png", "title": "截图标题4", "desc": "描述文字"}
      ]
    },

    // ==================================================================
    // 4. 对比页（左右对比）
    // ==================================================================
    {
      "type": "compare",
      "filename": "001-method-04-compare",
      "comparePageNum": "03",
      "sectionTitle": "对比标题",
      "leftHeader": "以前",
      "leftSub": "子标题",
      "leftItems": [
        {"label": "领域", "value": "具体内容"},
        {"label": "结果", "value": "具体内容"}
      ],
      "vsText": "VS",
      "rightHeader": "现在",
      "rightSub": "子标题",
      "rightItems": [
        {"label": "领域", "value": "具体内容"},
        {"label": "结果", "value": "具体内容"}
      ],
      "summaryText": "底部总结"
    },

    // ==================================================================
    // 5. 文字段落页（金句/行动号召）
    // ==================================================================
    {
      "type": "text",
      "filename": "001-method-05-action",
      "pageNum": "04",
      "sectionTitle": "页面标题",
      "footerText": "底部文字",
      "lines": [
        "普通文字行",
        {"text": "高亮文字行", "highlight": true},
        "",
        "更多文字"
      ]
    },

    // ==================================================================
    // 6. 数据展示页（大数字统计）
    // ==================================================================
    {
      "type": "data",
      "filename": "001-method-06-data",
      "pageNum": "05",
      "sectionTitle": "数据标题",
      "footerText": "底部文字",
      "stats": [
        {"value": "47", "label": "累计", "highlight": false},
        {"value": "81-27k", "label": "范围", "highlight": false},
        {"value": "1.8%-25.9%", "label": "比例范围", "highlight": false},
        {"value": "平均10.4%", "label": "平均值", "highlight": true}
      ]
    },

    // ==================================================================
    // 7. 流程步骤页（纵向步骤）
    // ==================================================================
    {
      "type": "flow",
      "filename": "001-method-07-flow",
      "pageNum": "06",
      "sectionTitle": "流程标题",
      "footerText": "底部文字",
      "steps": [
        {"num": "1", "title": "步骤一", "desc": "描述文字"},
        {"num": "2", "title": "步骤二", "desc": "描述文字"},
        {"num": "3", "title": "步骤三", "desc": "描述文字"},
        {"num": "4", "title": "步骤四", "desc": "描述文字"}
      ]
    }
  ]
}
